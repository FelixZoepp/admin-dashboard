# Commerzbank has no API — use the `import-commerzbank-csv` Edge Function:
#   curl -X POST \
#     -H "Authorization: Bearer $SUPABASE_SERVICE_ROLE_KEY" \
#     -H "Content-Type: application/json" \
#     --data '{"csv": "<paste semicolon-separated Commerzbank export>"}' \
#     https://imdcuumthauvrfhghqtz.supabase.co/functions/v1/import-commerzbank-csv
