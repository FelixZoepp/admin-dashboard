# --- Supabase (Frontend) ---
NEXT_PUBLIC_SUPABASE_URL=https://imdcuumthauvrfhghqtz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (Server / Service Role) ---
