SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
SHARE_LINK_SECRET=replace-with-random-32-char-string

# --- Integration secrets (set these in Supabase Edge Function Secrets, NOT here) ---
